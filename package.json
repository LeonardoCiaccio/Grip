{
  "name": "grip",
  "version": "1.0.0",
  "description": "Global Registry with Interceptors Pipeline — a lightweight JavaScript framework for organizing, protecting, and observing business logic.",
  "main": "core/grip.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "build": "npx terser core/grip.js --compress passes=3 --mangle --module --output core/grip.min.js",
    "example": "node scripts/serve-examples.js"
  },
  "keywords": ["grip", "registry", "interceptors", "pipeline", "hooks", "business-logic"],
  "author": "Leonardo Ciaccio",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "babel-jest": "^30.0.4",
    "jest": "^30.0.4"
  }
}
